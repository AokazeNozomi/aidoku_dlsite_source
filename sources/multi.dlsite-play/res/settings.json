				"refreshes": [
					"listings",
					"content"
				]
			}
		]
	},
	{
		"type": "group",
		"title": "Work Types",
		"items": [
			{
				"type": "multi-select",
				"key": "wt_images",
				"title": "Images",
				"values": ["MNG", "SCM", "WBT", "ICG", "NRE", "DNV"],
				"titles": ["Manga", "Gekiga", "Webtoon", "CG / Illustrations", "Novel", "Digital Novel"],
