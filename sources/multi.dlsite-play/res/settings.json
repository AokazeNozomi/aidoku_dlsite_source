[
	{
		"type": "group",
		"title": "Account",
		"footer": "Log in with your DLsite account to access purchased works.",
		"items": [
			{
				"type": "login",
				"method": "web",
				"key": "login",
				"title": "Login",
				"url": "https://play.dlsite.com/login",
				"refreshes": [
					"listings",
					"content"
				]
			}
		]
	},
	{
		"type": "group",
		"title": "Display",
		"items": [
			{
				"type": "select",
				"key": "preferred_language",
				"title": "Preferred Title and Genre Language",
				"values": [
					"English",
					"Japanese",
					"Chinese (Simplified)",
					"Chinese (Traditional)",
					"Korean"
				],
				"default": "English",
				"refreshes": [
					"listings",
					"content"
				]
			},
			{
				"type": "switch",
				"key": "series_prefix",
				"title": "Show [SERIES] prefix",
