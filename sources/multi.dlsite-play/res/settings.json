				"refreshes": ["listings", "content"]
			},
			{
				"type": "multi-select",
				"key": "wt_av",
				"title": "Audio / Video",
				"values": ["MOV", "SOU", "MUS"],
				"titles": ["Video", "Voice / ASMR", "Music"],
				"default": [],
				"refreshes": ["listings", "content"]
			},
			{
				"type": "multi-select",
				"key": "wt_game",
				"title": "Game",
				"values": ["ACN", "QIZ", "ADV", "RPG", "TBL", "SLN", "TYP", "STG", "PZL", "ETC"],
				"titles": ["Action", "Quiz", "Adventure", "Role-playing", "Table", "Simulation", "Typing", "Shooting", "Puzzle", "Miscellaneous"],
				"default": [],
				"refreshes": ["listings", "content"]
			},
			{
				"type": "multi-select",
				"key": "wt_tools",
				"title": "Tools / Accessories",
				"values": ["TOL", "IMT", "AMT"],
				"titles": ["Tools / Accessories", "Illustration Materials", "Music Materials"],
				"default": ["IMT"],
				"refreshes": ["listings", "content"]
			},
			{
				"type": "multi-select",
				"key": "wt_misc",
				"title": "Miscellaneous",
				"values": ["ET3", "VCM", "PBC"],
				"titles": ["Miscellaneous", "Voiced Comic", "Publication"],
				"default": [],
				"refreshes": ["listings", "content"]
			}
		]
	},
	{
		"type": "group",
		"title": "Sort",
		"footer": "Default sort order for library listings.",
		"items": [
			{
				"type": "select",
				"key": "default_sort",
				"title": "Default Sort",
				"values": [
					"Recently Opened",
					"Purchase Date",
					"Release Date",
					"Writer/Circle Name",
					"Title"
