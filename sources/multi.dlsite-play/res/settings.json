				"default": "Recently Opened",
				"refreshes": [
					"listings",
					"content"
				]
			},
			{
				"type": "switch",
				"key": "default_sort_ascending",
				"title": "Ascending",
				"subtitle": "Sort in ascending order instead of descending.",
